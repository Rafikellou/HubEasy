# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Slack Webhook Configuration (for Luke contact notifications)
# Get your webhook URL from: https://api.slack.com/apps
# 1. Create a new app: https://api.slack.com/apps → "Create New App"
# 2. Enable "Incoming Webhooks"
# 3. Add webhook to your workspace
# 4. Copy the webhook URL here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace 'your_openai_api_key_here' with your actual OpenAI API key
# 3. Replace the Slack webhook URL with your actual webhook
# 4. Make sure .env.local is in your .gitignore (it should be by default)
# 5. Restart your development server after adding the keys
